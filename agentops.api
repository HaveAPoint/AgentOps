syntax = "v1"

type (
	LoginReq {
		Username string `json:"username"`
		Password string `json:"password"`
	}
	LoginResp {
		AccessToken string `json:"accessToken"`
		ExpiresIn   int64  `json:"expiresIn"`
	}
	CreateTaskReq {
		Title            string   `json:"title"`
		RepoPath         string   `json:"repoPath"`
		Prompt           string   `json:"prompt"`
		ReviewerId       string   `json:"reviewerId,optional"`
		OperatorId       string   `json:"operatorId,optional"`
		Mode             string   `json:"mode,options=analyze|patch"`
		ApprovalRequired bool     `json:"approvalRequired,optional"`
		MaxSteps         int64    `json:"maxSteps,default=10"`
		AllowedPaths     []string `json:"allowedPaths,optional"`
		DeniedPaths      []string `json:"deniedPaths,optional"`
	}
	CreateTaskResp {
		Id     string `json:"id"`
		Status string `json:"status"`
	}
	GetTaskReq {
		Id string `path:"id"`
	}
	GetTaskLogsReq {
		Id string `path:"id"`
	}
	TaskItem {
		Id               string `json:"id"`
		Title            string `json:"title"`
		RepoPath         string `json:"repoPath"`
		Mode             string `json:"mode"`
		Status           string `json:"status"`
		ApprovalRequired bool   `json:"approvalRequired"`
		CreatorId        string `json:"creatorId"`
		GitBranch        string `json:"gitBranch"`
		GitHeadCommit    string `json:"gitHeadCommit"`
		GitDirty         bool   `json:"gitDirty"`
		CreatedAt        string `json:"createdAt"`
		UpdatedAt        string `json:"updatedAt"`
	}
	TaskListResp {
		Items []TaskItem `json:"items"`
	}
	TaskDetailResp {
		Id               string   `json:"id"`
		Title            string   `json:"title"`
		RepoPath         string   `json:"repoPath"`
		Prompt           string   `json:"prompt"`
		Mode             string   `json:"mode"`
		Status           string   `json:"status"`
		ApprovalRequired bool     `json:"approvalRequired"`
		MaxSteps         int64    `json:"maxSteps"`
		AllowedPaths     []string `json:"allowedPaths"`
		DeniedPaths      []string `json:"deniedPaths"`
		CreatorId        string   `json:"creatorId"`
		ReviewerId       string   `json:"reviewerId"`
		OperatorId       string   `json:"operatorId"`
		ApprovedBy       string   `json:"approvedBy"`
		ApprovedAt       string   `json:"approvedAt"`
		CancelledBy      string   `json:"cancelledBy"`
		CancelledAt      string   `json:"cancelledAt"`
		GitBranch        string   `json:"gitBranch"`
		GitHeadCommit    string   `json:"gitHeadCommit"`
		GitDirty         bool     `json:"gitDirty"`
		CreatedAt        string   `json:"createdAt"`
		UpdatedAt        string   `json:"updatedAt"`
	}
	ApproveTaskReq {
		Id                string `path:"id"`
		ExpectedUpdatedAt string `json:"expectedUpdatedAt"`
		Reason            string `json:"reason,optional"`
	}
	ApproveTaskResp {
		Id     string `json:"id"`
		Status string `json:"status"`
	}
	StartTaskReq {
		Id string `path:"id"`
	}
	StartTaskResp {
		Id     string `json:"id"`
		Status string `json:"status"`
	}
	SucceedTaskReq {
		Id            string `path:"id"`
		ResultSummary string `json:"resultSummary,optional"`
	}
	SucceedTaskResp {
		Id     string `json:"id"`
		Status string `json:"status"`
	}
	FailTaskReq {
		Id            string `path:"id"`
		ResultSummary string `json:"resultSummary,optional"`
		ErrorMessage  string `json:"errorMessage"`
	}
	FailTaskResp {
		Id     string `json:"id"`
		Status string `json:"status"`
	}
	CancelTaskReq {
		Id     string `path:"id"`
		Reason string `json:"reason,optional"`
	}
	CancelTaskResp {
		Id     string `json:"id"`
		Status string `json:"status"`
	}
	LogItem {
		Step       int64  `json:"step"`
		Level      string `json:"level"`
		Message    string `json:"message"`
		ToolName   string `json:"toolName"`
		OccurredAt string `json:"occurredAt"`
	}
	TaskLogsResp {
		Items []LogItem `json:"items"`
	}
	GetTaskExecutionsReq {
		Id string `path:"id"`
	}
	GetTaskStatusHistoriesReq {
		Id string `path:"id"`
	}
	ExecutionItem {
		Id            string `json:"id"`
		TaskId        string `json:"taskId"`
		OperatorId    string `json:"operatorId"`
		Status        string `json:"status"`
		StartedAt     string `json:"startedAt"`
		FinishedAt    string `json:"finishedAt"`
		ResultSummary string `json:"resultSummary"`
		ErrorMessage  string `json:"errorMessage"`
	}
	TaskExecutionsResp {
		Items []ExecutionItem `json:"items"`
	}
	StatusHistoryItem {
		Id         string `json:"id"`
		FromStatus string `json:"fromStatus"`
		ToStatus   string `json:"toStatus"`
		Action     string `json:"action"`
		ActorId    string `json:"actorId"`
		ActorRole  string `json:"actorRole"`
		Reason     string `json:"reason"`
		CreatedAt  string `json:"createdAt"`
	}
	TaskStatusHistoriesResp {
		Items []StatusHistoryItem `json:"items"`
	}
)

@server (
	group:  auth
	prefix: /api/v1
)
service agentops-api {
	@handler Login
	post /auth/login (LoginReq) returns (LoginResp)
}

@server (
	group:  tasks
	prefix: /api/v1
	jwt:    Auth
)
service agentops-api {
	@handler CreateTask
	post /tasks (CreateTaskReq) returns (CreateTaskResp)

	@handler StartTask
	post /tasks/:id/start (StartTaskReq) returns (StartTaskResp)

	@handler SucceedTask
	post /tasks/:id/succeed (SucceedTaskReq) returns (SucceedTaskResp)

	@handler FailTask
	post /tasks/:id/fail (FailTaskReq) returns (FailTaskResp)

	@handler ListTasks
	get /tasks returns (TaskListResp)

	@handler GetTask
	get /tasks/:id (GetTaskReq) returns (TaskDetailResp)

	@handler ApproveTask
	post /tasks/:id/approve (ApproveTaskReq) returns (ApproveTaskResp)

	@handler CancelTask
	post /tasks/:id/cancel (CancelTaskReq) returns (CancelTaskResp)

	@handler GetTaskLogs
	get /tasks/:id/logs (GetTaskLogsReq) returns (TaskLogsResp)

	@handler GetTaskExecutions
	get /tasks/:id/executions (GetTaskExecutionsReq) returns (TaskExecutionsResp)

	@handler GetTaskStatusHistories
	get /tasks/:id/status-histories (GetTaskStatusHistoriesReq) returns (TaskStatusHistoriesResp)
}

